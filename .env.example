LIBRARIAN_API_HOST=127.0.0.1
LIBRARIAN_API_PORT=8080
LIBRARIAN_API_KEY=
LIBRARIAN_API_IMPORT_ROOT=
LIBRARIAN_API_MAX_UPLOAD_BYTES=104857600
LIBRARIAN_DATA_DIR=.librarian
LIBRARIAN_DATABASE_PATH=.librarian/librarian.sqlite
LIBRARIAN_JOB_BACKEND=in-process
LIBRARIAN_LOG_FORMAT=json
LIBRARIAN_LOG_LEVEL=INFO
LIBRARIAN_LLM_PROVIDER=mock
LIBRARIAN_LLM_MODEL=mock-cleaner
LIBRARIAN_LLM_BASE_URL=
LIBRARIAN_LLM_API_KEY_ENV=OPENAI_API_KEY
LIBRARIAN_LLM_MAX_CONCURRENCY=8
LIBRARIAN_LLM_MAX_RETRIES=5
LIBRARIAN_LLM_RETRY_BASE_DELAY_SECONDS=0.5
LIBRARIAN_LLM_RETRY_MAX_DELAY_SECONDS=10.0
LIBRARIAN_OCR_LANGUAGE=eng
LIBRARIAN_OCR_TIMEOUT_SECONDS=120
LIBRARIAN_OCR_PDF_DPI=200
LIBRARIAN_OCR_PDF_MAX_PAGES=100
LIBRARIAN_UNIVERSAL_MAX_INPUT_BYTES=52428800
LIBRARIAN_UNIVERSAL_TIMEOUT_SECONDS=120
OPENAI_API_KEY=

